# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here
CHAT_MODEL=gpt-4-turbo
ANALYSIS_MODEL=gpt-3.5-turbo

# ===== StudentBot Parameters =====
STUDENT_TEMPERATURE=0.7        # 0.0-2.0 (높을수록 창의적)
STUDENT_MAX_TOKENS=150         # 최대 응답 길이

# ===== TutorBot Parameters =====
TUTOR_TEMPERATURE=0.3          # 0.0-2.0 (일관적인 피드백)
TUTOR_MAX_TOKENS=100           # 최대 피드백 길이
TUTOR_INTERVENTION_THRESHOLD=3 # 질문 10개당 개입 횟수 (1-10)

# Session Security
SESSION_SECRET=change-this-to-random-64-char-string

# Database
DATABASE_URL=sqlite+aiosqlite:///./dialogue_sim.db

# Server
HOST=0.0.0.0
PORT=8000

# Environment (development or production)
# Set to "production" to enable HTTPS-only cookies and security features
ENV=development
