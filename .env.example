# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here

# ===== Model Configuration (Responses API) =====
# All services use Responses API (Phase 1 & 1.5 complete)
#
# Supported models:
# - gpt-5 (recommended, Aug 2025)
# - gpt-5.1 (GPT-5.1 Thinking, adaptive reasoning)
# - gpt-5.1-chat-latest (GPT-5.1 Instant, fast)
# - gpt-4-turbo (fallback if GPT-5 unavailable)
#
# NOT supported: gpt-3.5 (Responses API limitation)
#
CHAT_MODEL=gpt-5-mini
ANALYSIS_MODEL=gpt-5.2
DIALOGUE_ANALYSIS_MODEL=gpt-5.2  # Model for dialogue similarity analysis
# Fallback example: CHAT_MODEL=gpt-4-turbo

# ===== GPT-5/5.1 Reasoning Effort Configuration =====
# Model-specific valid values:
# - GPT-5: minimal, low, medium, high
# - GPT-5.1: none, low, medium, high (note: "minimal" not supported)
#
# Reasoning effort levels:
# - none: Minimal reasoning, fastest (GPT-5.1 only, default for GPT-5.1)
# - minimal: Quick responses (GPT-5 only)
# - low: Simple tasks, faster responses
# - medium: Balanced quality and speed
# - high: Maximum reasoning, highest quality (slowest)
#
# Recommendations by model:
# - gpt-5.1 with fast responses: use "none" or "low"
# - gpt-5 with fast responses: use "minimal" or "low"
# - Complex analysis: use "high" for batch analysis tasks
#
ANALYSIS_REASONING=high                        # Legacy shared analysis default
ANALYSIS_MISCONCEPTION_REASONING=low          # Real-time misconception analysis
ANALYSIS_CLASSIFICATION_REASONING=low         # End-session teacher question classification
ANALYSIS_GREETING_REASONING=low               # End-session greeting/non-educational filtering
ANALYSIS_SYNTHESIS_REASONING=high             # End-session coaching feedback synthesis
STUDENT_REASONING=medium                      # Student chat responses
TUTOR_REASONING=low                           # Tutor feedback

# ===== Bot Token Limits =====
# CRITICAL: GPT-5 with reasoning effort uses tokens for both reasoning AND output.
# Set max_output_tokens high enough to accommodate reasoning + actual response.
#
STUDENT_MAX_TOKENS=1500                       # Student response budget
TUTOR_MAX_TOKENS=1500                         # Tutor feedback budget
ANALYSIS_MISCONCEPTION_MAX_TOKENS=500        # Real-time misconception analysis
ANALYSIS_CLASSIFICATION_MAX_TOKENS=2500      # Classification first attempt
ANALYSIS_CLASSIFICATION_RETRY_MAX_TOKENS=4000
ANALYSIS_GREETING_MAX_TOKENS=1000            # Greeting detection first attempt
ANALYSIS_GREETING_RETRY_MAX_TOKENS=1500
ANALYSIS_SYNTHESIS_MAX_TOKENS=8000           # Session feedback synthesis first attempt
ANALYSIS_SYNTHESIS_RETRY_MAX_TOKENS=12000
DIALOGUE_ANALYSIS_MAX_TOKENS=200             # Dialogue similarity analysis
TUTOR_INTERVENTION_THRESHOLD=3               # Questions per 10 before tutor intervention
CONTEXT_WINDOW_TURNS=20                      # Dialogue turns retained in prompt context

# Session Security
SESSION_SECRET=change-this-to-random-64-char-string

# Database
DATABASE_URL=sqlite+aiosqlite:///./dialogue_sim.db

# Server
HOST=0.0.0.0
PORT=8000

# Environment (development or production)
# Set to "production" to enable HTTPS-only cookies and security features
ENV=development
